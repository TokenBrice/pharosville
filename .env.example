PHAROS_API_BASE=https://api.pharos.watch
# Set PHAROS_API_KEY as a Cloudflare Pages secret, not in browser-exposed Vite env.
# For local `npm run dev`, set PHAROS_API_KEY in one of:
# - `.env.local` in the current worktree
# - `.env.local` in the main worktree (auto-discovered from linked worktrees)
# - `.git/pharosville.env.local` (shared across all worktrees)
# - your shell environment
# Use `npm run setup:local-api-key` to initialize/update `.git/pharosville.env.local`.
# PHAROS_API_KEY=ph_live_...
