/*
  Security policy for PharosVille static assets and app shell.
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), ambient-light-sensor=(), autoplay=(), battery=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; img-src 'self' data: https://*.google-analytics.com; style-src 'self'; script-src 'self' https://www.googletagmanager.com https://static.cloudflareinsights.com; connect-src 'self' https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://static.cloudflareinsights.com; frame-ancestors 'none'; form-action 'self'

# Vite emits hashed filenames into /assets/, so these are safe to long-cache.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The runtime asset manifest is the cache-version root: a short TTL with
# stale-while-revalidate avoids re-downloading ~70KB on every navigation while
# still picking up asset waves within minutes.
/pharosville/assets/manifest.runtime.json
  Cache-Control: public, max-age=300, stale-while-revalidate=3600

# Sprite files are cache-busted by the ?v=<manifest cacheVersion> query that
# the runtime appends, so the underlying paths are safe to long-cache. Listed
# per subdirectory (not /pharosville/assets/*) so the manifest rule above is
# the only rule matching the manifest.
/pharosville/assets/docks/*
  Cache-Control: public, max-age=31536000, immutable
/pharosville/assets/landmarks/*
  Cache-Control: public, max-age=31536000, immutable
/pharosville/assets/overlays/*
  Cache-Control: public, max-age=31536000, immutable
/pharosville/assets/props/*
  Cache-Control: public, max-age=31536000, immutable
/pharosville/assets/ships/*
  Cache-Control: public, max-age=31536000, immutable
/pharosville/assets/terrain/*
  Cache-Control: public, max-age=31536000, immutable
