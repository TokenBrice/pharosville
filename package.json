{
  "name": "pharosville",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:visual": "playwright test tests/visual/pharosville.spec.ts",
    "test:visual:no-reuse": "PHAROSVILLE_VISUAL_REUSE=0 playwright test tests/visual/pharosville.spec.ts",
    "test:visual:dist": "playwright test tests/visual/pharosville.spec.ts --config=playwright.dist.config.ts",
    "test:visual:dist:static": "playwright test tests/visual/pharosville.spec.ts --config=playwright.dist.config.ts --grep \"desktop canvas shell|dense visual|stressed ship|named risk water|narrow fallback|short desktop fallback|desktop gate|resizing below|ultrawide\"",
    "test:visual:dist:interaction": "playwright test tests/visual/pharosville.spec.ts --config=playwright.dist.config.ts --grep \"canvas interactions|reduced motion keeps|live reduced-motion\"",
    "test:visual:dist:motion": "playwright test tests/visual/pharosville.spec.ts --config=playwright.dist.config.ts --grep \"normal motion\"",
    "test:visual:accessibility": "playwright test tests/visual/pharosville.spec.ts --grep \"accessibility\"",
    "test:visual:cross-browser": "PHAROSVILLE_VISUAL_BROWSERS=\"chromium,firefox\" npx playwright test tests/visual/pharosville.spec.ts --grep \"accessibility\"",
    "test:visual:dist:accessibility": "PHAROSVILLE_VISUAL_BROWSERS=\"chromium,firefox\" npx playwright test tests/visual/pharosville.spec.ts --config=playwright.dist.config.ts --grep \"accessibility\"",
    "test:visual:dist:accessibility:firefox": "PHAROSVILLE_VISUAL_BROWSERS=\"firefox\" npx playwright test tests/visual/pharosville.spec.ts --config=playwright.dist.config.ts --grep \"accessibility\"",
    "onboard:agent": "node scripts/pharosville/onboard-agent.mjs",
    "agent:init": "node scripts/pharosville/agent-init.mjs",
    "setup:local-api-key": "node scripts/pharosville/setup-local-api-key.mjs",
    "smoke:api-local": "node scripts/pharosville/smoke-local-api.mjs",
    "smoke:dev-proxy": "node scripts/pharosville/smoke-dev-proxy.mjs",
    "worktree:new": "node scripts/pharosville/new-worktree.mjs",
    "agent:plan:new": "node scripts/pharosville/new-agent-plan.mjs",
    "validate:changed": "node scripts/pharosville/validate-changed.mjs",
    "check:pharosville-assets": "node scripts/pharosville/validate-assets.mjs",
    "check:pharosville-colors": "node scripts/check-pharosville-colors.mjs",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "check:committed-secrets": "node scripts/check-committed-secrets.mjs",
    "check:branch-protection": "node scripts/pharosville/check-branch-protection.mjs",
    "check:security-headers": "node scripts/pharosville/check-security-headers.mjs --url https://pharosville.pharos.watch",
    "check:doc-paths-and-scripts": "node scripts/check-doc-paths-and-scripts.mjs",
    "test:guard-scripts": "node scripts/check-guards.test.mjs",
    "hooks:install": "git config core.hooksPath .githooks",
    "smoke:live": "node scripts/smoke-live.mjs",
    "check:release-admin": "npm run check:branch-protection",
    "check:release-readiness": "npm run check:security-headers && npm run test:visual:cross-browser && npm run test:visual:dist:accessibility && npm run smoke:live -- --url https://pharosville.pharos.watch",
    "validate:docs": "npm run test:guard-scripts && npm run check:doc-paths-and-scripts",
    "validate": "npm run check:committed-secrets && npm run validate:docs && npm run check:pharosville-assets && npm run check:pharosville-colors && npm run typecheck && npm test && npm run build && npm run check:bundle-size",
    "validate:release": "npm run validate && npm run test:visual:dist && npm run test:visual:dist:accessibility",
    "deploy": "wrangler pages deploy dist --project-name=pharosville"
  },
  "dependencies": {
    "@tanstack/react-query": "5.99.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^29.0.2",
    "playwright": "1.59.1",
    "tsx": "^4.20.6",
    "typescript": "~5.9.0",
    "vite": "^7.2.8",
    "vitest": "^4.1.4",
    "wrangler": "4.83.0"
  }
}
