#!/usr/bin/env bash
set -euo pipefail

needs_release_gate=0
needs_changed_gate=0
updates=()

while read -r local_ref local_sha remote_ref remote_sha; do
  updates+=("$local_ref $local_sha $remote_ref $remote_sha")

  if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
    continue
  fi

  if [[ "$remote_ref" == refs/heads/* ]]; then
    if [[ "$remote_ref" == "refs/heads/main" ]]; then
      needs_release_gate=1
    else
      needs_changed_gate=1
    fi
  fi
done

if [[ "$needs_release_gate" == "1" ]]; then
  echo "Running PharosVille deploy gate before pushing main..."
  npm run validate:deploy-gate
elif [[ "$needs_changed_gate" == "1" ]]; then
  echo "Running PharosVille changed-files gate before pushing non-main branches..."
  printf '%s\n' "${updates[@]}" | npm run validate:changed -- --pre-push --remote "${1:-origin}"
else
  echo "No branch updates detected; skipping PharosVille pre-push validation gates."
fi
